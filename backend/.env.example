# Backend environment — copy to .env and adjust for your setup
#
# Docker Compose (defaults below use service names):
#   MONGO_URI=mongodb://mongodb:27017/cinema
#   REDIS_ADDR=redis:6379
#   RABBITMQ_URL=amqp://cinema:cinema@rabbitmq:5672/
#
# Local dev with cloud services (example):
#   MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cinema
#   REDIS_ADDR=your-redis-host:6379
#   RABBITMQ_URL=amqps://user:pass@host/vhost

PORT=8080
MONGO_URI=mongodb://mongodb:27017/cinema
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_TLS=false
LOCK_TTL_SECONDS=300
RABBITMQ_URL=amqp://cinema:cinema@rabbitmq:5672/
JWT_SECRET=dev-secret-change-in-production
FIREBASE_CREDENTIALS=./firebase-key.json
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
